# Database
DATABASE_URL="postgresql://bistro:bistro@localhost:5433/bistro_dev?schema=public"

# Auth
JWT_SECRET="change-me-to-32-bytes-of-randomness"
JWT_REFRESH_SECRET="change-me-too-to-32-bytes-of-randomness"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Leave all three blank to disable Google sign-in. If GOOGLE_CLIENT_ID is
# set, GOOGLE_CALLBACK_URL MUST also be set — there is no localhost fallback
# (a previous default was masking misconfigured production deploys).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# AI provider
ANTHROPIC_API_KEY=""
# Optional — Anthropic model alias. Defaults to claude-sonnet-4-6 if unset.
# (CLAUDE.md still lists claude-sonnet-4-20250514; that alias retires
# 2026-06-15. Use claude-sonnet-4-6 for new deploys.)
ANTHROPIC_MODEL=""

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:8081"
