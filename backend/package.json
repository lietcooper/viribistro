{
  "name": "bistro-backend",
  "version": "0.1.0",
  "private": true,
  "description": "The Intelligent Bistro — Node.js + Express API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "lint:schema": "prisma validate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcrypt": "6.0.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.22.2",
    "express-async-errors": "3.1.1",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "prisma": "5.22.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cookie-parser": "1.4.7",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.10.1",
    "@types/passport": "1.0.16",
    "@types/passport-google-oauth20": "2.0.16",
    "@types/supertest": "6.0.2",
    "pino-pretty": "13.0.0",
    "supertest": "7.0.0",
    "tsx": "4.21.0",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
